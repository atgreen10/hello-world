#include <stdio.h>
#include <cs50.h>
#include <string.h>
#include <stdlib.h>
#include <ctype.h>

//variable
int k;
int q;


int main (int argc, string argv[])
{
    // sets the key for encryption
    if (argc == 2)
    {
        string key = argv[1];
        printf ("Key: %s\n", key);
    }

    //quits program with bad input
    else
    {
        printf("Ya done messed up...\n");
        return 1;
    }

    // turns key to an integer
    k = atoi(argv[1]);
    if (k <= 0)
    {
        printf("Can Not Be Negative Number");
    }
    else
    {
        printf("key as int: %i \n", k);
    }

    //plaintext input and length
    string str = get_string ("Message:  ");
    int length = strlen(str);
    printf("%i \n",length);
    int i = str[0];

    for (i = str[i]; i < (length - 1); i++)
    {
        if (isalpha(str))
        {
            char m = str[i];
            if (islower(str))
            {
                //gets alphabetical index
                 int alpha = (m - 'a');
                // printf("for alpha: %i \n", alpha);
                //equation we had to use
                int a = ((alpha + k) %26);
                // printf("after equation: %i ", a);
                printf("this is a: %i",a);
            }

            if (isupper(str))
            {
                //alpha index
                int alph = (m - 'A');
                // printf("%i", alph);
                //equation we had to use
                int b = ((alph + k) %26);
                // printf("after equation: %i \n", b);
                printf("this is b:  %i",b);
            }
        }


    }
    return 0;
}
